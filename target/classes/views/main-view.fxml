<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<VBox fx:id="rootContainer" prefHeight="800.0" prefWidth="1200.0" styleClass="page-root"
   stylesheets="@../css/styles.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MainController">
   <children>

      <!-- Barre supérieure compacte -->
      <HBox fx:id="titleBar" alignment="CENTER_LEFT"
            styleClass="title-bar"
            prefHeight="40.0" minHeight="40.0" maxHeight="40.0" spacing="12.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="title-bar-brand">
               <children>
                  <Label text="MediClinic" styleClass="title-bar-appname"/>
               </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10.0" styleClass="title-bar-actions">
               <children>
                  <Button fx:id="btnWinMin" onAction="#handleMinimizeWindow" styleClass="apple-btn, apple-btn-minimize"/>
                  <Button fx:id="btnWinMax" onAction="#handleMaximizeWindow" styleClass="apple-btn, apple-btn-maximize"/>
                  <Button fx:id="btnWinClose" onAction="#handleCloseWindow" styleClass="apple-btn, apple-btn-close"/>
               </children>
            </HBox>
         </children>
      </HBox>

      <!-- Corps : Barre latérale + Contenu -->
      <HBox VBox.vgrow="ALWAYS">
         <children>

            <!-- ── Barre latérale ── -->
            <VBox styleClass="sidebar" prefWidth="220.0" minWidth="220.0" maxWidth="220.0" spacing="18.0">
               <children>

                  <!-- En-tête de marque -->
                  <VBox spacing="12.0" styleClass="sidebar-header" alignment="CENTER_LEFT">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <ImageView fx:id="imgLogo" fitWidth="36.0" fitHeight="36.0" pickOnBounds="true" preserveRatio="true" styleClass="sidebar-logo-image" />
                              <VBox spacing="2.0">
                                 <children>
                                    <Label text="MediClinic" styleClass="sidebar-brand-main"/>
                                    <Label text="Clinique intelligente" styleClass="sidebar-brand-sub"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- Groupe de navigation -->
                  <Label text="Navigation" styleClass="sidebar-section-label"/>
                  <VBox spacing="10.0" styleClass="sidebar-menu">
                     <children>
                        <Button fx:id="btnDashboard" text="  Tableau de Bord" onAction="#showDashboardView" styleClass="sidebar-nav-btn, sidebar-nav-active"/>
                        <Button fx:id="btnPatients" text="  Patients" onAction="#showPatientsView" styleClass="sidebar-nav-btn"/>
                        <Button fx:id="btnAppointments" text="  Rendez-vous" onAction="#showAppointmentsView" styleClass="sidebar-nav-btn"/>
                     </children>
                  </VBox>

                  <Region VBox.vgrow="ALWAYS"/>

                  <!-- Informations de pied de page -->
                  <VBox spacing="10.0" styleClass="sidebar-footer-card">
                     <children>
                        <Label text="Organisation claire" styleClass="sidebar-footer-name"/>
                        <Label text="Un espace de travail propre pour votre clinique." styleClass="sidebar-footer-sub" wrapText="true"/>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- ── Contenu principal ── -->
            <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"
                       styleClass="content-pane">
               <children>

                  <!-- Volet du tableau de bord par défaut -->
                  <VBox fx:id="dashboardPane" spacing="24.0" styleClass="page-content">
                     <children>

                        <!-- En-tête de page -->
                        <VBox spacing="4.0">
                           <children>
                              <Label text="Tableau de Bord" styleClass="page-title"/>
                              <Label text="Aperçu en temps réel des opérations de la clinique."
                                     styleClass="page-subtitle"/>
                           </children>
                        </VBox>

                        <!-- Cartes de statistiques -->
                        <HBox spacing="20.0">
                           <children>

                              <!-- Carte 1 -->
                              <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="TOTAL PATIENTS" styleClass="stat-label"/>
                                    <Label fx:id="lblTotalPatients" text="0" styleClass="stat-value"/>
                                    <Label text="Enregistrés dans la base" styleClass="stat-hint"/>
                                 </children>
                              </VBox>

                              <!-- Carte 2 -->
                              <VBox styleClass="stat-card, stat-card-purple" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="RENDEZ-VOUS" styleClass="stat-label"/>
                                    <Label fx:id="lblTotalAppointments" text="0" styleClass="stat-value"/>
                                    <Label text="Total des réservations" styleClass="stat-hint"/>
                                 </children>
                              </VBox>

                              <!-- Carte 3 -->
                              <VBox styleClass="stat-card, stat-card-green" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="À VENIR" styleClass="stat-label"/>
                                    <Label fx:id="lblUpcomingAppointments" text="0" styleClass="stat-value"/>
                                    <Label text="Consultations programmées" styleClass="stat-hint"/>
                                 </children>
                              </VBox>

                           </children>
                        </HBox>

                        <!-- Zone d'alimentation divisée -->
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                           <children>
                              
                              <!-- Colonne gauche : Tableau des rendez-vous à venir -->
                              <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="form-card">
                                 <children>
                                    <Label text="  Prochains Rendez-vous" styleClass="form-card-title"/>
                                    <TableView fx:id="tableDashAppointments" VBox.vgrow="ALWAYS" styleClass="medi-table">
                                       <columns>
                                          <TableColumn fx:id="colDashDate" text="Date &amp; Heure" prefWidth="140.0"/>
                                          <TableColumn fx:id="colDashPatient" text="Patient" prefWidth="150.0"/>
                                          <TableColumn fx:id="colDashDoctor" text="Médecin" prefWidth="130.0"/>
                                          <TableColumn fx:id="colDashStatus" text="État" prefWidth="100.0"/>
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>

                              <!-- Colonne droite : Carte d'actions rapides -->
                              <VBox spacing="16.0" prefWidth="280.0" minWidth="280.0" maxWidth="280.0" styleClass="form-card">
                                 <children>
                                    <Label text="  Raccourcis &amp; Actions" styleClass="form-card-title"/>
                                    <Label text="Actions rapides pour accélérer votre travail quotidien." styleClass="page-subtitle" wrapText="true"/>
                                    
                                    <Button fx:id="btnQuickAddPatient" text="  Nouveau Patient"
                                            onAction="#handleQuickAddPatient"
                                            styleClass="btn-primary-purple" prefWidth="232.0"/>
                                            
                                    <Button fx:id="btnQuickBookAppointment" text="  Planifier un RDV"
                                            onAction="#handleQuickBookAppointment"
                                            styleClass="btn-outline" prefWidth="232.0"/>
                                            
                                    <Region VBox.vgrow="ALWAYS"/>

                                 </children>
                              </VBox>

                           </children>
                        </HBox>

                     </children>
                  </VBox>

               </children>
            </StackPane>

         </children>
      </HBox>

   </children>
</VBox>
