<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PatientController">
   <children>
      <!-- En-tête -->
      <VBox spacing="6.0" styleClass="page-header">
         <children>
            <Label styleClass="label-header" text="Gestion des Patients" />
            <Label styleClass="label-sub" text="Ajoutez, modifiez ou supprimez les informations des patients de la clinique." />
         </children>
      </VBox>
      
      <!-- Contenu principal : Formulaire à gauche, Tableau à droite -->
      <HBox spacing="25.0" VBox.vgrow="ALWAYS">
         <children>
            
            <!-- Côté gauche : Conteneur de formulaire -->
            <VBox spacing="20.0" styleClass="panel-card" prefWidth="350.0" HBox.hgrow="NEVER">
               <children>
                  <Label text="Formulaire Patient" styleClass="section-title" />
                  
                  <!-- Grille des champs de formulaire -->
                  <GridPane vgap="12.0" hgap="10.0">
                     <columnConstraints>
                        <!-- Les contraintes de colonne peuvent être vides ou génériques -->
                     </columnConstraints>
                     <children>
                        <!-- Prénom -->
                        <Label text="Prénom :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtFirstName" promptText="Ex: Jean" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" />
                        
                        <!-- Nom de famille -->
                        <Label text="Nom de famille :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtLastName" promptText="Ex: Dupont" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />
                        
                        <!-- Âge -->
                        <Label text="Âge :" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtAge" promptText="Ex: 45" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        
                        <!-- Genre -->
                        <Label text="Genre :" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cmbGender" promptText="Sélectionner" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="150.0">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="Male" />
                                 <String fx:value="Female" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        
                        <!-- Numéro de téléphone -->
                        <Label text="Téléphone :" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtPhoneNumber" promptText="Ex: 0612345678" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" />
                     </children>
                  </GridPane>
                  
                  <!-- Boutons d'action du formulaire -->
                  <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 10px 0 0 0;">
                     <children>
                        <Button fx:id="btnClear" mnemonicParsing="false" onAction="#handleClearForm" styleClass="btn, btn-secondary" text="Vider" />
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSavePatient" styleClass="btn, btn-success" text="Enregistrer" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Côté droit : Conteneur de vue tableau -->
            <VBox spacing="15.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
               <children>
                  <!-- Barre de recherche et actions -->
                  <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="toolbar-row">
                     <children>
                        <TextField fx:id="txtSearch" promptText="Rechercher par nom, prénom ou téléphone..." HBox.hgrow="ALWAYS" styleClass="search-field" />
                        <Button fx:id="btnDetails" mnemonicParsing="false" onAction="#handleDetailsPatient" styleClass="btn, btn-secondary" text="Détails" />
                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDeletePatient" styleClass="btn, btn-danger" text="Supprimer" />
                     </children>
                  </HBox>
                  
                  <!-- Vue tableau des patients -->
                  <TableView fx:id="tablePatients" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableClick" styleClass="data-table">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="colFirstName" prefWidth="120.0" text="Prénom" />
                      <TableColumn fx:id="colLastName" prefWidth="120.0" text="Nom" />
                      <TableColumn fx:id="colAge" prefWidth="60.0" text="Âge" />
                      <TableColumn fx:id="colGender" prefWidth="90.0" text="Genre" />
                      <TableColumn fx:id="colPhoneNumber" prefWidth="150.0" text="Téléphone" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
            
         </children>
      </HBox>
   </children>
</VBox>
