<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="page-root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AppointmentController">
   <children>
      <!-- En-tête -->
      <VBox spacing="6.0" styleClass="page-header">
         <children>
            <Label styleClass="label-header" text="Gestion des Rendez-vous" />
            <Label styleClass="label-sub" text="Planifiez les consultations médicales, assignez des médecins et suivez le calendrier." />
         </children>
      </VBox>
      
      <!-- Contenu principal : Formulaire à gauche, Tableau à droite -->
      <HBox spacing="25.0" VBox.vgrow="ALWAYS">
         <children>
            
            <!-- Côté gauche : Conteneur de formulaire -->
            <VBox spacing="20.0" styleClass="panel-card" prefWidth="350.0" HBox.hgrow="NEVER">
               <children>
                  <Label text="Planifier un Rendez-vous" styleClass="section-title" />
                  
                  <!-- Grille des champs de formulaire -->
                  <GridPane vgap="12.0" hgap="10.0">
                     <children>
                        <!-- Sélection du patient -->
                        <Label text="Patient :" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cmbPatient" promptText="Choisir un patient..." GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" prefWidth="310.0" />
                        
                        <!-- Nom du médecin -->
                        <Label text="Médecin :" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtDoctorName" promptText="Ex: Dr. Martin" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" />
                        
                        <!-- Étiquette de date au-dessus du sélecteur de date -->
                        <Label text="Date :" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                        <DatePicker fx:id="dpDate" promptText="Sélectionner..." GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" prefWidth="310.0" editable="false" />

                        <!-- Étiquette d'heure au-dessus des sélecteurs d'heure -->
                        <Label text="Heure :" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;" />
                        <HBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2">
                           <children>
                              <!-- Heure -->
                              <ComboBox fx:id="cmbHour" prefWidth="90.0" promptText="HH" styleClass="time-combo">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="08" /><String fx:value="09" /><String fx:value="10" />
                                       <String fx:value="11" /><String fx:value="12" /><String fx:value="13" />
                                       <String fx:value="14" /><String fx:value="15" /><String fx:value="16" />
                                       <String fx:value="17" /><String fx:value="18" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <Label text=":" style="-fx-font-size: 16px; -fx-padding: 2px 0 0 0;" />
                              <!-- Minute -->
                              <ComboBox fx:id="cmbMinute" prefWidth="90.0" promptText="MM" styleClass="time-combo">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="00" /><String fx:value="15" />
                                       <String fx:value="30" /><String fx:value="45" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                           </children>
                        </HBox>
                        
                        <!-- Description -->
                        <Label text="Motif / Description :" GridPane.columnIndex="0" GridPane.rowIndex="8" style="-fx-font-weight: bold;" />
                        <TextArea fx:id="txtDescription" prefHeight="80.0" promptText="Détails du motif médical..." GridPane.columnIndex="0" GridPane.rowIndex="9" GridPane.columnSpan="2" wrapText="true" style="-fx-font-size: 13px;" />
                     </children>
                  </GridPane>
                  
                  <!-- Boutons d'action du formulaire -->
                  <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 5px 0 0 0;">
                     <children>
                        <Button fx:id="btnClear" mnemonicParsing="false" onAction="#handleClearForm" styleClass="btn, btn-secondary" text="Vider" />
                        <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSaveAppointment" styleClass="btn, btn-success" text="Enregistrer" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Côté droit : Conteneur de vue tableau -->
            <VBox spacing="15.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
               <children>
                  <!-- Barre de recherche et actions -->
                  <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="toolbar-row">
                     <children>
                        <TextField fx:id="txtSearch" promptText="Rechercher par médecin ou nom de patient..." HBox.hgrow="ALWAYS" styleClass="search-field" />
                        <Button fx:id="btnDetails" mnemonicParsing="false" onAction="#handleDetailsAppointment" styleClass="btn, btn-secondary" text="Détails" />
                        <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDeleteAppointment" styleClass="btn, btn-danger" text="Supprimer" />
                     </children>
                  </HBox>
                  
                  <!-- Vue tableau des rendez-vous -->
                  <TableView fx:id="tableAppointments" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableClick" styleClass="data-table">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="colDate" prefWidth="140.0" text="Date &amp; Heure" />
                      <TableColumn fx:id="colPatientName" prefWidth="150.0" text="Patient" />
                      <TableColumn fx:id="colDoctorName" prefWidth="120.0" text="Médecin" />
                      <TableColumn fx:id="colDescription" prefWidth="180.0" text="Motif / Description" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
            
         </children>
      </HBox>
   </children>
</VBox>
